{
  "name": "@brandonwie/dayjs-util",
  "version": "0.3.0",
  "description": "Timezone-safe date utility wrapper for dayjs — built for calendar applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./event": {
      "import": {
        "types": "./dist/event.d.ts",
        "default": "./dist/event.js"
      },
      "require": {
        "types": "./dist/event.d.cts",
        "default": "./dist/event.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "date",
    "timezone",
    "dayjs",
    "utc",
    "calendar",
    "date-util"
  ],
  "author": "brandonwie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonwie/dayjs-util.git"
  },
  "peerDependencies": {
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "dayjs": "^1.11.13",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
